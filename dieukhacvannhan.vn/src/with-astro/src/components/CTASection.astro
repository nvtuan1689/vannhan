---
interface Props {
  phone: string;
  email: string;
  zalo: string;
  location: string;
  hours: string;
}

const { phone, email, zalo, location, hours } = Astro.props;
const phoneHref = `tel:${phone.replace(/\s+/g, '')}`;
---

<section id="lien-he" class="section-space pt-8">
  <div class="section-shell">
    <div class="surface-card overflow-hidden px-6 py-8 sm:px-8 lg:px-10 lg:py-10">
      <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div>
          <span class="eyebrow">Liên hệ & đặt dự án</span>
          <h2 class="section-title max-w-3xl">Hãy bắt đầu từ một ý tưởng, chúng tôi sẽ cùng bạn phát triển thành tác phẩm hoàn chỉnh.</h2>
          <p class="section-copy max-w-2xl">
            Gửi mô tả không gian, kích thước dự kiến hoặc hình tham khảo — Điêu Khắc Văn Nhân sẽ đề xuất hướng thiết kế, chất liệu và quy trình thi công phù hợp.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href={phoneHref} class="btn-primary">Gọi ngay · {phone}</a>
            <a href={zalo} class="btn-secondary" target="_blank" rel="noreferrer">Nhắn Zalo</a>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="surface-card h-full bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-stone-400">Hotline</p>
            <a href={phoneHref} class="mt-3 block font-display text-3xl text-stone-950">{phone}</a>
            <p class="mt-2 text-sm leading-7 text-stone-500">Tư vấn ý tưởng, chất liệu và tiến độ thực hiện.</p>
          </div>
          <div class="surface-card h-full bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-stone-400">Email</p>
            <a href={`mailto:${email}`} class="mt-3 block break-all font-medium text-stone-950">{email}</a>
            <p class="mt-2 text-sm leading-7 text-stone-500">Phù hợp khi gửi ảnh tham khảo hoặc brief chi tiết.</p>
          </div>
          <div class="surface-card h-full bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-stone-400">Khu vực hoạt động</p>
            <p class="mt-3 font-display text-3xl text-stone-950">TP.HCM</p>
            <p class="mt-2 text-sm leading-7 text-stone-500">{location}</p>
          </div>
          <div class="surface-card h-full bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-stone-400">Thời gian làm việc</p>
            <p class="mt-3 font-display text-3xl text-stone-950">7 ngày/tuần</p>
            <p class="mt-2 text-sm leading-7 text-stone-500">{hours}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
