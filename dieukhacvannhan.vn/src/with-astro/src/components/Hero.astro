---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface HeroStat {
  value: string;
  label: string;
}

interface HeroAction {
  label: string;
  href: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  primaryAction: HeroAction;
  secondaryAction: HeroAction;
  image: ImageMetadata;
  alt: string;
  highlight: string;
  stats: HeroStat[];
}

const { eyebrow, title, description, primaryAction, secondaryAction, image, alt, highlight, stats } = Astro.props;
---

<section id="top" class="relative overflow-hidden px-4 pb-10 pt-6 sm:px-6 lg:px-8 lg:pb-16">
  <div class="section-shell surface-card muted-grid relative overflow-hidden px-6 py-8 sm:px-8 lg:px-12 lg:py-12">
    <div class="pointer-events-none absolute inset-x-0 top-0 h-48 bg-gradient-to-b from-white/75 to-transparent"></div>
    <div class="pointer-events-none absolute -right-20 top-10 size-64 rounded-full bg-bronze-300/25 blur-3xl"></div>
    <div class="grid items-center gap-10 lg:grid-cols-[1.04fr_0.96fr] lg:gap-14">
      <div class="relative z-10">
        <span class="eyebrow">{eyebrow}</span>
        <h1 class="mt-6 max-w-3xl font-display text-5xl leading-[0.98] text-stone-950 sm:text-6xl lg:text-7xl">
          {title}
        </h1>
        <p class="mt-6 max-w-2xl text-base leading-8 text-stone-600 sm:text-lg">
          {description}
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href={primaryAction.href} class="btn-primary">{primaryAction.label}</a>
          <a href={secondaryAction.href} class="btn-secondary">{secondaryAction.label}</a>
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-3">
          {stats.map((stat) => (
            <div class="rounded-[1.5rem] border border-white/60 bg-white/75 px-5 py-4 shadow-[0_18px_45px_rgba(30,22,16,0.06)]">
              <div class="font-display text-3xl text-stone-950 sm:text-4xl">{stat.value}</div>
              <div class="mt-1 text-sm leading-6 text-stone-500">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="relative z-10">
        <div class="absolute -left-4 top-8 hidden rounded-full border border-white/70 bg-white/90 px-4 py-2 text-xs uppercase tracking-[0.28em] text-stone-500 shadow-[0_16px_35px_rgba(23,19,17,0.09)] lg:block">
          Featured sculpture
        </div>
        <div class="overflow-hidden rounded-[2rem] border border-white/65 bg-stone-200/50 p-3 shadow-[0_30px_80px_rgba(23,19,17,0.18)]">
          <div class="overflow-hidden rounded-[1.55rem] bg-stone-100 [&_img]:h-full [&_img]:w-full [&_img]:object-cover">
            <Picture
              src={image}
              alt={alt}
              formats={["avif", "webp"]}
              widths={[640, 960, 1280, 1600]}
              sizes="(min-width: 1280px) 42vw, (min-width: 1024px) 44vw, 92vw"
              loading="eager"
              fetchpriority="high"
              priority
            />
          </div>
        </div>
        <div class="absolute -bottom-5 right-4 max-w-xs rounded-[1.5rem] border border-white/60 bg-white/90 px-5 py-4 shadow-[0_24px_60px_rgba(27,22,18,0.12)] backdrop-blur-md sm:right-8">
          <p class="text-xs uppercase tracking-[0.28em] text-stone-500">Tuyên ngôn chất lượng</p>
          <p class="mt-2 text-sm leading-6 text-stone-700">{highlight}</p>
        </div>
      </div>
    </div>
  </div>
</section>
