---
import type { NavLink } from '../data/homepage';

interface Props {
  links: NavLink[];
  phone: string;
  brandName: string;
  tagline: string;
}

const { links, phone, brandName, tagline } = Astro.props;
const phoneHref = `tel:${phone.replace(/\s+/g, '')}`;
---

<header class="sticky top-0 z-50 px-4 pt-4 sm:px-6 lg:px-8">
  <nav class="section-shell">
    <div class="glass-panel flex items-center justify-between gap-4 px-5 py-3 sm:px-6">
      <a href="#top" class="min-w-0">
        <div class="truncate font-display text-2xl text-stone-900 sm:text-3xl">{brandName}</div>
        <div class="hidden text-xs uppercase tracking-[0.24em] text-stone-500 sm:block">{tagline}</div>
      </a>

      <div class="hidden items-center gap-7 md:flex">
        {links.map((link) => (
          <a href={link.href} class="text-sm font-medium text-stone-600 hover:text-stone-900">{link.label}</a>
        ))}
      </div>

      <div class="hidden md:block">
        <a href={phoneHref} class="btn-primary px-5 py-3 text-xs sm:text-sm">
          <span class="size-2 rounded-full bg-emerald-400"></span>
          {phone}
        </a>
      </div>

      <details class="relative md:hidden">
        <summary class="flex cursor-pointer list-none items-center rounded-full border border-stone-200 bg-white/85 px-4 py-2 text-sm font-medium text-stone-700">
          Menu
        </summary>
        <div class="absolute right-0 top-[calc(100%+0.75rem)] w-72 overflow-hidden rounded-3xl border border-white/60 bg-white/95 p-3 shadow-[0_24px_60px_rgba(26,19,13,0.14)] backdrop-blur-xl">
          <ul class="space-y-1">
            {links.map((link) => (
              <li>
                <a href={link.href} class="block rounded-2xl px-4 py-3 text-sm text-stone-700 hover:bg-stone-100 hover:text-stone-950">{link.label}</a>
              </li>
            ))}
          </ul>
          <a href={phoneHref} class="btn-primary mt-3 w-full justify-center text-sm">
            Gọi tư vấn · {phone}
          </a>
        </div>
      </details>
    </div>
  </nav>
</header>
